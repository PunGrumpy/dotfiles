{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    }
  },
  "tools": {
    "linear_*": false
  },
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "/private/tmp/**": "allow",
      "~/.cargo/registry/**": "allow"
    }
  }
}
